# Copy this file to .env for local development.
#
# Pick one profile:
# - deviceLan: physical phone on the same Wi-Fi as the backend
# - androidEmulator: Android emulator using 10.0.2.2
# - iosSimulator: iOS simulator using localhost
# - web: Expo web using localhost
EXPO_PUBLIC_API_PROFILE=deviceLan

# Optional override. If set, this takes priority over EXPO_PUBLIC_API_PROFILE.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:5000

# Backend-only secret. Do not expose this with EXPO_PUBLIC_.
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional lightweight API token.
# If URBANGROW_API_TOKEN is set, protected POST endpoints require X-API-Token.
# Use the EXPO_PUBLIC value only for local/demo app builds, not high-security production.
# URBANGROW_API_TOKEN=change-this-local-token
# EXPO_PUBLIC_API_TOKEN=change-this-local-token

# Optional rate limit tuning.
# URBANGROW_RATE_LIMIT_WINDOW_SECONDS=60
# URBANGROW_RATE_LIMIT_MAX_REQUESTS=120
# URBANGROW_MAX_JSON_BODY_BYTES=8192

# Optional physical actuator integration.
# If this URL is set, backend will POST actuator commands directly to the ESP.
# If empty, commands stay pending and the ESP can poll /api/actuator-commands/next.
# URBANGROW_ESP_HTTP_CONTROL_URL=http://192.168.1.50/actuator
# URBANGROW_DEFAULT_DEVICE_ID=esp32-main
# URBANGROW_MQTT_COMMAND_TOPIC=urbangrow/actuator/commands
